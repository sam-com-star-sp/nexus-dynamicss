<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nexus Dynamics — Transformation Digitale & Stratégie</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #0d2882;
    --blue: #1a3ab5;
    --sky: #4db8e8;
    --sky-light: #87d4f5;
    --white: #ffffff;
    --off-white: #f4f8fd;
    --gray: #7a8aaa;
    --dark: #070f2b;
    --card-bg: #0e1e5a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: 'DM Sans', sans-serif; background: var(--dark); color: var(--white); overflow-x: hidden; }

  body::before {
    content: ''; position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none; z-index: 0; opacity: 0.6;
  }

  h1, h2, h3, h4, .nav-logo, .tab-label { font-family: 'Syne', sans-serif; }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 4%;
    background: rgba(7,15,43,0.9); backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(77,184,232,0.1);
  }
  .nav-logo {
    display: flex; align-items: center; gap: 0.6rem;
    font-weight: 800; font-size: 1.1rem; letter-spacing: -0.02em;
    text-decoration: none; color: var(--white);
  }
  .nav-logo-icon { width: 34px; height: 34px; display: grid; grid-template-columns: 1fr 1fr; gap: 3px; }
  .nav-logo-icon span { display: block; border-radius: 3px; }
  .nav-logo-icon span:nth-child(1) { background: var(--navy); border-radius: 6px 2px 2px 2px; }
  .nav-logo-icon span:nth-child(2) { background: var(--sky); border-radius: 2px 6px 2px 2px; }
  .nav-logo-icon span:nth-child(3) { background: var(--sky-light); border-radius: 2px 2px 2px 6px; }
  .nav-logo-icon span:nth-child(4) { background: var(--blue); border-radius: 2px 2px 6px 2px; }
  .nav-logo em { color: var(--sky); font-style: normal; }

  .nav-links { display: flex; gap: 1.4rem; list-style: none; align-items: center; }
  .nav-links a { color: rgba(255,255,255,0.65); text-decoration: none; font-size: 0.82rem; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; transition: color 0.2s; }
  .nav-links a:hover { color: var(--sky); }
  .nav-cta { background: var(--sky) !important; color: var(--dark) !important; padding: 0.45rem 1.2rem; border-radius: 50px; font-weight: 700 !important; }
  .nav-cta:hover { background: var(--sky-light) !important; }

  /* hamburger */
  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 5px; }
  .hamburger span { width: 24px; height: 2px; background: white; border-radius: 2px; transition: all 0.3s; }

  /* ── SECTIONS COMMON ── */
  section { padding: 6rem 5%; position: relative; }
  .section-label {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--sky); margin-bottom: 0.7rem;
    display: flex; align-items: center; gap: 0.5rem;
  }
  .section-label::before { content: ''; width: 20px; height: 2px; background: var(--sky); }
  .section-title { font-size: clamp(1.8rem, 3.5vw, 3rem); font-weight: 800; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 1rem; }
  .section-desc { font-size: 0.95rem; line-height: 1.8; color: rgba(255,255,255,0.6); max-width: 560px; }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp { from { opacity:0; transform:translateY(25px); } to { opacity:1; transform:none; } }
  @keyframes float1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-20px,30px)} }
  @keyframes float2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(15px,-20px)} }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
  .reveal { opacity:0; transform:translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal.visible { opacity:1; transform:none; }

  /* BUTTONS */
  .btn-primary {
    background: linear-gradient(135deg, var(--sky), var(--blue));
    color: white; text-decoration: none; border: none;
    padding: 0.85rem 2rem; border-radius: 50px;
    font-family: 'Syne',sans-serif; font-weight: 700; font-size: 0.9rem;
    cursor: pointer; display: inline-block;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 30px rgba(77,184,232,0.3);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(77,184,232,0.45); }
  .btn-secondary {
    background: transparent; color: white; text-decoration: none;
    padding: 0.85rem 2rem; border-radius: 50px; border: 1px solid rgba(255,255,255,0.2);
    font-family: 'Syne',sans-serif; font-weight: 600; font-size: 0.9rem;
    cursor: pointer; display: inline-block;
    transition: border-color 0.2s, background 0.2s;
  }
  .btn-secondary:hover { border-color: var(--sky); background: rgba(77,184,232,0.08); }
  .btn-outline-dark {
    background: transparent; color: var(--navy); text-decoration: none;
    padding: 0.75rem 1.8rem; border-radius: 50px; border: 2px solid var(--navy);
    font-family: 'Syne',sans-serif; font-weight: 700; font-size: 0.88rem;
    cursor: pointer; display: inline-block; transition: all 0.2s;
  }
  .btn-outline-dark:hover { background: var(--navy); color: white; }

  /* ── HERO ── */
  .hero {
    min-height: 100vh; display: flex; align-items: center;
    padding: 8rem 5% 5rem; position: relative; overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0; z-index: 0;
    background: radial-gradient(ellipse 80% 60% at 60% 40%, rgba(26,58,181,0.25) 0%, transparent 70%),
                radial-gradient(ellipse 50% 50% at 85% 70%, rgba(77,184,232,0.15) 0%, transparent 60%),
                var(--dark);
  }
  .hero-grid {
    position: absolute; inset: 0; z-index: 0;
    background-image: linear-gradient(rgba(77,184,232,0.05) 1px, transparent 1px),
                      linear-gradient(90deg, rgba(77,184,232,0.05) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 20%, transparent 80%);
  }
  .hero-orb { position: absolute; border-radius: 50%; filter: blur(80px); z-index: 0; pointer-events: none; }
  .hero-orb-1 { width: 500px; height: 500px; background: rgba(26,58,181,0.3); top: -100px; right: 10%; animation: float1 8s ease-in-out infinite; }
  .hero-orb-2 { width: 300px; height: 300px; background: rgba(77,184,232,0.2); bottom: 5%; left: 5%; animation: float2 10s ease-in-out infinite; }
  .hero-content { position: relative; z-index: 1; max-width: 780px; }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: rgba(77,184,232,0.12); border: 1px solid rgba(77,184,232,0.3);
    color: var(--sky); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.35rem 0.9rem; border-radius: 50px; margin-bottom: 1.8rem;
    animation: fadeUp 0.8s ease both;
  }
  .hero-tag::before { content: '●'; font-size: 0.5rem; animation: pulse 2s infinite; }
  .hero h1 { font-size: clamp(2.8rem,6vw,5.2rem); font-weight: 800; line-height: 1.05; letter-spacing: -0.03em; margin-bottom: 1.4rem; animation: fadeUp 0.8s ease 0.1s both; }
  .hero h1 .accent { color: var(--sky); }
  .hero h1 .line2 { display: block; color: rgba(255,255,255,0.45); font-weight: 400; }
  .hero-desc { font-size: 1.05rem; line-height: 1.75; color: rgba(255,255,255,0.65); max-width: 540px; margin-bottom: 2.5rem; animation: fadeUp 0.8s ease 0.2s both; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; animation: fadeUp 0.8s ease 0.3s both; }
  .hero-stats { position: absolute; right: 5%; bottom: 15%; z-index: 1; display: flex; flex-direction: column; gap: 1rem; animation: fadeUp 0.8s ease 0.4s both; }
  .stat-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(77,184,232,0.15); backdrop-filter: blur(10px); border-radius: 16px; padding: 1.2rem 1.8rem; text-align: center; transition: border-color 0.3s; }
  .stat-card:hover { border-color: rgba(77,184,232,0.4); }
  .stat-card .num { font-family:'Syne',sans-serif; font-size: 2rem; font-weight: 800; color: var(--sky); }
  .stat-card .lbl { font-size: 0.72rem; color: rgba(255,255,255,0.5); letter-spacing: 0.05em; }

  /* ── ABOUT ── */
  .about { background: var(--off-white); color: var(--dark); overflow: hidden; }
  .about .section-label { color: var(--blue); }
  .about .section-label::before { background: var(--blue); }
  .about .section-desc { color: rgba(7,15,43,0.65); }
  .about-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .about-visual { position: relative; height: 480px; }
  .about-card { position: absolute; border-radius: 20px; padding: 2rem; box-shadow: 0 20px 60px rgba(13,40,130,0.15); }
  .about-card-main { background: var(--navy); color: white; width: 78%; left: 0; top: 0; height: 320px; display: flex; flex-direction: column; justify-content: flex-end; overflow: hidden; }
  .about-card-main::before { content:'N'; position: absolute; top: -20px; right: -10px; font-family:'Syne',sans-serif; font-size: 14rem; font-weight: 800; color: rgba(77,184,232,0.08); line-height: 1; pointer-events: none; }
  .about-card-main h3 { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.5rem; }
  .about-card-main p { font-size: 0.88rem; color: rgba(255,255,255,0.6); line-height: 1.6; }
  .about-card-accent { background: linear-gradient(135deg, var(--sky), #2176b5); color: white; width: 55%; right: 0; bottom: 0; height: 200px; display: flex; flex-direction: column; justify-content: center; }
  .about-card-accent .big { font-family:'Syne',sans-serif; font-size: 2.5rem; font-weight: 800; line-height: 1; }
  .about-card-accent p { font-size: 0.82rem; opacity: 0.85; margin-top: 0.3rem; }
  .about-text .pills { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 2rem; }
  .pill { background: rgba(13,40,130,0.08); border: 1px solid rgba(13,40,130,0.15); color: var(--navy); padding: 0.35rem 0.9rem; border-radius: 50px; font-size: 0.8rem; font-weight: 600; }

  /* ── ACTIVITIES ── */
  .activities { background: var(--dark); }
  .acts-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; margin-top: 3rem; }
  .act-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(77,184,232,0.1); border-radius: 20px; padding: 2rem; transition: border-color 0.3s, transform 0.3s, background 0.3s; position: relative; overflow: hidden; }
  .act-card:hover { border-color: rgba(77,184,232,0.35); transform: translateY(-4px); background: rgba(255,255,255,0.05); }
  .act-num { font-family:'Syne',sans-serif; font-size: 0.68rem; font-weight: 700; color: var(--sky); letter-spacing: 0.1em; margin-bottom: 1rem; opacity: 0.7; }
  .act-icon { width: 46px; height: 46px; border-radius: 12px; background: linear-gradient(135deg, rgba(77,184,232,0.2), rgba(26,58,181,0.2)); display: flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 1rem; }
  .act-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.6rem; }
  .act-card p { font-size: 0.85rem; color: rgba(255,255,255,0.55); line-height: 1.7; }

  /* ── DOMAINES TABS ── */
  .domaines { background: #080f2e; }
  .domaines .section-label::before { background: var(--sky); }
  .tabs-nav { display: flex; gap: 0.5rem; margin: 2.5rem 0 2rem; flex-wrap: wrap; }
  .tab-btn {
    background: rgba(255,255,255,0.04); border: 1px solid rgba(77,184,232,0.15);
    color: rgba(255,255,255,0.6); padding: 0.6rem 1.4rem; border-radius: 50px;
    font-family:'Syne',sans-serif; font-weight: 600; font-size: 0.82rem;
    cursor: pointer; transition: all 0.25s; letter-spacing: 0.03em;
  }
  .tab-btn:hover, .tab-btn.active { background: var(--sky); border-color: var(--sky); color: var(--dark); }
  .tab-content { display: none; }
  .tab-content.active { display: grid; grid-template-columns: 1fr 1.2fr; gap: 4rem; align-items: start; animation: fadeUp 0.4s ease both; }
  .tab-info h3 { font-size: 1.8rem; font-weight: 800; margin-bottom: 1rem; }
  .tab-info p { font-size: 0.92rem; color: rgba(255,255,255,0.65); line-height: 1.75; margin-bottom: 1.5rem; }
  .tab-features { display: flex; flex-direction: column; gap: 0.7rem; margin-top: 1rem; }
  .tab-feature { display: flex; align-items: center; gap: 0.7rem; font-size: 0.88rem; color: rgba(255,255,255,0.7); }
  .tab-feature::before { content:'✓'; color: var(--sky); font-weight: 700; flex-shrink: 0; }
  .tab-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .tab-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(77,184,232,0.1); border-radius: 16px; padding: 1.5rem; transition: border-color 0.3s; }
  .tab-card:hover { border-color: rgba(77,184,232,0.3); }
  .tab-card .tc-icon { font-size: 1.6rem; margin-bottom: 0.7rem; }
  .tab-card h4 { font-size: 0.9rem; font-weight: 700; margin-bottom: 0.4rem; }
  .tab-card p { font-size: 0.8rem; color: rgba(255,255,255,0.5); line-height: 1.6; }

  /* ── TEAM NAME/BIO PLACEHOLDERS ── */
  .team-name-placeholder {
    font-family:'Syne',sans-serif; font-size:0.75rem; font-weight:700;
    letter-spacing:0.08em; text-transform:uppercase;
    color:var(--blue); background:rgba(13,40,130,0.06);
    border:1px dashed rgba(13,40,130,0.2); border-radius:8px;
    padding:0.3rem 0.7rem; margin-bottom:0.5rem; display:inline-block;
  }
  .team-bio-placeholder {
    font-size:0.72rem; color:rgba(7,15,43,0.35); font-style:italic;
    border-left:2px solid rgba(13,40,130,0.12); padding-left:0.6rem;
    margin-top:0.5rem; margin-bottom:0.2rem;
  }

  /* ── ORG TABS ── */
  .org-tab-content { animation: fadeUp 0.4s ease both; }

  /* ── TEAM ── */
  .team { background: var(--off-white); color: var(--dark); }
  .team .section-label { color: var(--blue); }
  .team .section-label::before { background: var(--blue); }
  .team-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; flex-wrap: wrap; gap: 1.5rem; }
  .team-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1.5rem; }
  .team-card { background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 20px rgba(13,40,130,0.07); transition: transform 0.3s, box-shadow 0.3s; }
  .team-card:hover { transform: translateY(-6px); box-shadow: 0 20px 50px rgba(13,40,130,0.15); }
  .team-avatar { height: 180px; display: flex; align-items: center; justify-content: center; font-size: 4rem; position: relative; }
  .team-avatar-bg-1 { background: linear-gradient(135deg, #0d2882, #1a3ab5); }
  .team-avatar-bg-2 { background: linear-gradient(135deg, #1a3ab5, #4db8e8); }
  .team-avatar-bg-3 { background: linear-gradient(135deg, #4db8e8, #87d4f5); }
  .team-avatar-bg-4 { background: linear-gradient(135deg, #0a1a60, #0d2882); }
  .team-avatar-bg-5 { background: linear-gradient(135deg, #2176b5, #4db8e8); }
  .team-avatar-bg-6 { background: linear-gradient(135deg, #051040, #1a3ab5); }
  .team-info { padding: 1.4rem; }
  .team-info h4 { font-size: 1rem; font-weight: 800; color: var(--navy); margin-bottom: 0.25rem; }
  .team-info .role { font-size: 0.78rem; color: var(--sky); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.6rem; }
  .team-info p { font-size: 0.8rem; color: rgba(7,15,43,0.55); line-height: 1.6; }
  .team-info .socials { display: flex; gap: 0.5rem; margin-top: 0.8rem; }
  .team-info .socials a { width: 28px; height: 28px; border-radius: 50%; background: rgba(13,40,130,0.08); display: flex; align-items: center; justify-content: center; font-size: 0.75rem; color: var(--navy); text-decoration: none; transition: background 0.2s; }
  .team-info .socials a:hover { background: var(--sky); color: white; }

  /* ── APPROACH ── */
  .approach { background: var(--dark); overflow: hidden; }
  .approach-inner { display: grid; grid-template-columns: 1fr 1.4fr; gap: 6rem; align-items: center; }
  .steps { display: flex; flex-direction: column; gap: 0; margin-top: 2.5rem; position: relative; }
  .steps::before { content:''; position: absolute; left: 20px; top: 0; bottom: 0; width: 1px; background: linear-gradient(to bottom, transparent, rgba(77,184,232,0.4), transparent); }
  .step { display: flex; gap: 1.5rem; padding: 1.5rem 0; cursor: pointer; transition: all 0.3s; }
  .step-dot { width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0; border: 2px solid rgba(77,184,232,0.3); display: flex; align-items: center; justify-content: center; background: var(--dark); font-family:'Syne',sans-serif; font-weight: 700; font-size: 0.82rem; color: rgba(255,255,255,0.4); position: relative; z-index: 1; transition: all 0.3s; }
  .step.active .step-dot { background: linear-gradient(135deg, var(--sky), var(--blue)); border-color: transparent; color: white; box-shadow: 0 0 20px rgba(77,184,232,0.4); }
  .step-body h4 { font-weight: 700; font-size: 0.95rem; margin-bottom: 0.3rem; }
  .step-body p { font-size: 0.83rem; color: rgba(255,255,255,0.5); line-height: 1.6; }
  .step.active .step-body h4 { color: var(--sky); }
  .approach-visual { background: rgba(255,255,255,0.02); border: 1px solid rgba(77,184,232,0.1); border-radius: 28px; padding: 3rem; min-height: 380px; display: flex; flex-direction: column; justify-content: space-between; position: relative; overflow: hidden; }
  .approach-visual::before { content:''; position: absolute; bottom: -60px; right: -60px; width: 220px; height: 220px; border-radius: 50%; background: radial-gradient(circle, rgba(77,184,232,0.12), transparent 70%); }
  .approach-visual h3 { font-size: 1.8rem; font-weight: 800; line-height: 1.2; }
  .approach-visual h3 span { color: var(--sky); }
  .visual-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2rem; }
  .metric { background: rgba(255,255,255,0.04); border-radius: 14px; padding: 1.2rem; border: 1px solid rgba(255,255,255,0.06); }
  .metric .val { font-family:'Syne',sans-serif; font-size: 1.5rem; font-weight: 800; color: var(--sky); }
  .metric .key { font-size: 0.73rem; color: rgba(255,255,255,0.45); margin-top: 0.2rem; }

  /* ── VALUES ── */
  .values { background: var(--off-white); color: var(--dark); }
  .values .section-label { color: var(--blue); }
  .values .section-label::before { background: var(--blue); }
  .values-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; flex-wrap: wrap; gap: 1rem; }
  .vals-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
  .val-card { background: white; border-radius: 20px; padding: 2rem; border: 1px solid rgba(13,40,130,0.08); box-shadow: 0 4px 20px rgba(13,40,130,0.06); transition: transform 0.3s, box-shadow 0.3s; position: relative; overflow: hidden; }
  .val-card::before { content:''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--navy), var(--sky)); transform: scaleX(0); transform-origin: left; transition: transform 0.3s; }
  .val-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(13,40,130,0.12); }
  .val-card:hover::before { transform: scaleX(1); }
  .val-emoji { font-size: 2rem; margin-bottom: 1rem; }
  .val-card h3 { font-size: 1rem; font-weight: 800; color: var(--navy); margin-bottom: 0.5rem; }
  .val-card p { font-size: 0.83rem; color: rgba(7,15,43,0.6); line-height: 1.7; }

  /* ── VISION ── */
  .vision { background: linear-gradient(135deg, var(--navy) 0%, #0a1a5c 50%, #051040 100%); overflow: hidden; position: relative; }
  .v
